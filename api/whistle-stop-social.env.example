# Vercel → Project → Settings → Environment Variables
# Copy values from E:\Nothing (Knight Logics Facebook-Runner / X-Runner .env files)

# Optional API key — staff can also post using admin login (no per-device key needed)
WS_SOCIAL_API_KEY=

# Whistle Stop admin password hash (data/site.json admin.passwordHash) — enables cross-device posting after login
WS_ADMIN_PASSWORD_HASH=

# Facebook Graph API (Knight Logics Page for demo, or Whistle Stop Page when ready)
WS_FB_PAGE_ID=
WS_FB_PAGE_ACCESS_TOKEN=

# X API — OAuth 1.0a (recommended; supports images)
WS_X_API_KEY=
WS_X_API_SECRET=
WS_X_ACCESS_TOKEN=
WS_X_ACCESS_TOKEN_SECRET=

# Optional OAuth2 bearer fallback (text-only if OAuth1 keys missing)
# WS_X_BEARER_TOKEN=
