{
  "name": "knightlogics-site",
  "private": true,
  "scripts": {
    "dev": "node scripts/sync-serve-json.js && npx serve -l 4183 --no-port-switching .",
    "dev:full": "npx vercel dev --listen 4199 --yes",
    "dev:stack": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-knight-command-stack.ps1",
    "dev:static": "npx serve -l 4183 --no-port-switching .",
    "qa:screenshots": "node scripts/qa-screenshot-matrix.js",
    "qa:hero-devices": "node scripts/qa-hero-cross-device.js --strict",
    "qa:screenshots:services": "node scripts/qa-screenshot-matrix.js --profile=knightlogics-services",
    "qa:screenshots:client-demo": "node scripts/qa-screenshot-matrix.js --profile=client-demo",
    "qa:lighthouse": "node scripts/qa-lighthouse.js",
    "stripe:sync-catalog": "node scripts/sync-knightlogics-stripe-catalog.js",
    "reviews:sync-google": "node scripts/sync-google-reviews.js",
    "test:whistle-stop-content": "node scripts/whistle-stop-content-smoke.js"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "busboy": "^1.6.0",
    "stripe": "^22.1.0"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
