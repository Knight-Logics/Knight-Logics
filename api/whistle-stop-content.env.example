# Vercel -> Project -> Settings -> Environment Variables
# These values stay server-side. Do not put them in GitHub Pages JavaScript.

# Required: SHA-256 hash of the Whistle Stop admin password.
# The publish endpoint requires the actual password over HTTPS and compares it server-side.
WS_ADMIN_PASSWORD_HASH=

# Required: GitHub fine-grained token with Contents: Read/Write on Knight-Logics/Whistle-Stop.
WS_CONTENT_GITHUB_TOKEN=

# Optional overrides.
WS_CONTENT_REPO=Knight-Logics/Whistle-Stop
WS_CONTENT_BRANCH=master
WS_CONTENT_LIVE_VERSION_URL=https://knight-logics.github.io/Whistle-Stop/data/content-version.json

# Optional machine key for automation only. Browser admin does not need this.
WS_CONTENT_PUBLISH_KEY=
